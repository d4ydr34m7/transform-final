# Backend env template. Copy to .env and fill in. Do not commit .env.

# GitHub (for /repos and clone)
GITHUB_TOKEN=
GITHUB_USER=

# S3 (optional; omit or false for local analysis_outputs/)
S3_ENABLED=false
S3_BUCKET=
# Optional: AWS profile for Bedrock, SNS (leave empty for default)
AWS_PROFILE=
AWS_REGION=us-east-1

# Bedrock Agent + Knowledge Base (chat + post-analysis sync)
BEDROCK_ENABLED=false
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
BEDROCK_KB_ID=
# Data source ID for StartIngestionJob after each analysis (find in KB → data source details).
BEDROCK_KB_DATA_SOURCE_ID=
# Optional: agent read timeout in seconds (default 60).
BEDROCK_AGENT_TIMEOUT_SECONDS=60

# Transform (atx CLI). Output dir name under repo where atx writes docs (default Documentation).
TRANSFORM_ENABLED=false
TRANSFORM_TIMEOUT_SECONDS=21600
TRANSFORM_OUTPUT_DIR=Documentation

# SNS: email when analysis completes. Requires SNS topic + Email subscription (confirm via email link).
SEND_COMPLETION_NOTIFICATION=false
SNS_TOPIC_ARN=
